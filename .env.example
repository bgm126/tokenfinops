# ══════════════════════════════════════════════
# TokenFinOps Configuration
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════

# ── Database ──
DATABASE_URL=postgresql+asyncpg://tokenfinops:tokenfinops@localhost:5432/tokenfinops
REDIS_URL=redis://localhost:6379/0

# ── LLM Providers (add keys for providers you want to use) ──
# At minimum, configure ONE provider. Ollama requires no key.
OPENAI_API_KEY=              # Optional: sk-...
OPENAI_BASE_URL=             # Optional: custom endpoint (e.g., Azure OpenAI)
ANTHROPIC_API_KEY=           # Optional: sk-ant-...
GEMINI_API_KEY=              # Optional: AIza...
OLLAMA_BASE_URL=http://localhost:11434   # Default: local Ollama
VLLM_BASE_URL=               # Optional: http://localhost:8000
OPENROUTER_API_KEY=          # Optional: access 100+ models via OpenRouter

# ── Embedding Model (for semantic cache) ──
# Options: "sentence-transformers", "openai", "ollama", "cohere"
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2      # For sentence-transformers
# EMBEDDING_MODEL=text-embedding-3-small  # For OpenAI
# EMBEDDING_MODEL=nomic-embed-text        # For Ollama

# ── Feature Flags ──
ENABLE_SEMANTIC_CACHE=true
ENABLE_PROMPT_OPTIMIZATION=true
ENABLE_MODEL_ROUTING=true
ENABLE_BUDGET_ENFORCEMENT=true
CACHE_SIMILARITY_THRESHOLD=0.95
CACHE_TTL_SECONDS=3600

# ── Routing ──
DEFAULT_ROUTING_STRATEGY=balanced  # lowest_cost | best_quality | balanced | budget_aware
DEFAULT_MODEL=                      # Leave empty for auto-routing

# ── Rate Limits ──
RATE_LIMIT_RPM=60             # Requests per minute per API key
RATE_LIMIT_TPM=100000         # Tokens per minute per API key
